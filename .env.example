# Model Configuration
MODEL__MODEL_NAME=damo-vilab/text-to-video-ms-1.7b
MODEL__DEVICE=cuda
MODEL__TORCH_DTYPE=float16
MODEL__USE_SAFETENSORS=true
MODEL__ENABLE_XFORMERS=false

# Generation Configuration
GEN__NUM_INFERENCE_STEPS=25
GEN__GUIDANCE_SCALE=7.5
GEN__NUM_FRAMES=16
GEN__HEIGHT=256
GEN__WIDTH=256
GEN__FPS=8

# API Configuration
API__HOST=0.0.0.0
API__PORT=8000
API__WORKERS=1
API__RELOAD=false
API__LOG_LEVEL=info
API__MAX_CONCURRENT_REQUESTS=5
API__TIMEOUT_SECONDS=300

# Storage Configuration
STORAGE__OUTPUT_DIR=./outputs
STORAGE__CACHE_DIR=./cache
STORAGE__TEMP_DIR=./temp